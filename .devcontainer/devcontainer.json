{
    "name": "Photolog",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    // photolog フォルダをコンテナのルートとして認識させる
    "workspaceFolder": "/workspaces/photolog",
    "runArgs": [
        "--env-file", ".env",
        "--label", "my-app=photolog"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "amazonwebservices.aws-toolkit-vscode"
            ]
        }
    },
    "remoteUser": "vscode",
    "containerEnv": {
        "TZ": "Asia/Tokyo"
    },
    "forwardPorts": [5173], // Viteローカルサーバのポート転送
    "portsAttributes": {
        "5173": {
          "label": "Vite Dev Server",
          "onAutoForward": "notify"
        }
    },
    "mounts": [ //実アップロードデータフォルダのマウント
        "source=N:/download/megpict,target=/workspaces/photolog/local_processor/real-data,type=bind,consistency=cached"
    ]
}