{
    "name": "Photolog",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspaces/photolog",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "amazonwebservices.aws-toolkit-vscode"
            ]
        }
    },
    "remoteUser": "vscode",
    "forwardPorts": [5173],
    "portsAttributes": {
        "5173": {
          "label": "Vite Dev Server",
          "onAutoForward": "notify"
        }
    }
    // "mounts" は削除（docker-compose.yml の volumes で管理するため）
}